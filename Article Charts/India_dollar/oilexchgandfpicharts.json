{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "spacing": 24,
  "config": {
    "background": null,
    "view": {"stroke": null},
    "font": "system-ui, sans-serif",
    "title": {"fontSize": 11, "color": "#374151", "anchor": "start"},
    "axisX": {
      "labelFontSize": 11,
      "labelColor": "#6B7280",
      "tickColor": "#6B7280",
      "domainColor": "rgba(0,0,0,0.12)",
      "gridColor": "transparent",
      "tickSize": 4,
      "labelAngle": 0,
      "title": null
    },
    "axisY": {
      "labelFontSize": 11,
      "labelColor": "#6B7280",
      "tickColor": "transparent",
      "domainColor": "transparent",
      "gridColor": "rgba(0,0,0,0.06)",
      "gridWidth": 1,
      "title": null
    }
  },
  "hconcat": [
    {
      "width": 260,
      "height": 220,
      "title": "Panel A   Brent crude ($ per barrel)",
      "data": {
        "url": "https://raw.githubusercontent.com/vkumarilse/vkumarilse.github.io/refs/heads/main/brentcrudeoilpriceeia.csv",
        "format": {
          "type": "csv",
          "parse": {
            "Month": "date:'%b %Y'",
            "Brent Spot Price FOB  Dollars per Barrel": "number"
          }
        }
      },
      "transform": [
        {
          "filter": "isValid(datum['Brent Spot Price FOB  Dollars per Barrel'])"
        },
        {"filter": "year(datum.Month) == 2026"},
        {
          "calculate": "datum['Brent Spot Price FOB  Dollars per Barrel']",
          "as": "brent"
        },
        {"sort": [{"field": "Month", "order": "ascending"}]}
      ],
      "layer": [
        {
          "data": {"values": [{"d": "2026-02-28"}]},
          "mark": {
            "type": "rule",
            "strokeDash": [4, 3],
            "strokeWidth": 1.5,
            "color": "#9CA3AF"
          },
          "encoding": {"x": {"field": "d", "type": "temporal"}}
        },
        {
          "mark": {
            "type": "area",
            "line": {"strokeWidth": 2.5, "color": "#DC2626"},
            "point": {"filled": true, "size": 50, "color": "#DC2626"},
            "color": "#DC2626",
            "opacity": 0.1,
            "interpolate": "monotone",
            "clip": true
          },
          "encoding": {
            "x": {
              "field": "Month",
              "type": "temporal",
              "scale": {"domain": ["2025-12-20", "2026-05-30"]},
              "axis": {
                "values": [
                  "2026-01-01",
                  "2026-02-01",
                  "2026-03-01",
                  "2026-04-01",
                  "2026-05-01"
                ],
                "format": "%b"
              }
            },
            "y": {
              "field": "brent",
              "type": "quantitative",
              "scale": {"domain": [55, 130]},
              "axis": {
                "values": [60, 80, 100, 120],
                "labelExpr": "'$' + datum.value"
              }
            },
            "tooltip": [
              {
                "field": "Month",
                "type": "temporal",
                "format": "%B %Y",
                "title": "Month"
              },
              {
                "field": "brent",
                "type": "quantitative",
                "format": ".1f",
                "title": "$/barrel"
              }
            ]
          }
        }
      ]
    },
    {
      "width": 260,
      "height": 220,
      "title": "Panel B   Net FPI flows (US$ million)",
      "data": {
        "values": [
          {"date": "2026-01-01", "fpi": -3235},
          {"date": "2026-02-01", "fpi": 4167},
          {"date": "2026-03-01", "fpi": -13600},
          {"date": "2026-04-01", "fpi": -7559},
          {"date": "2026-05-01", "fpi": -3083}
        ]
      },
      "layer": [
        {
          "data": {"values": [{"d": "2026-02-28"}]},
          "mark": {
            "type": "rule",
            "strokeDash": [4, 3],
            "strokeWidth": 1.5,
            "color": "#9CA3AF"
          },
          "encoding": {"x": {"field": "d", "type": "temporal"}}
        },
        {
          "mark": {"type": "rule", "color": "#D1D5DB", "strokeWidth": 1},
          "encoding": {"y": {"datum": 0, "type": "quantitative"}}
        },
        {
          "mark": {
            "type": "line",
            "point": {"filled": true, "size": 50, "color": "#7C3AED"},
            "strokeWidth": 2.5,
            "color": "#7C3AED",
            "interpolate": "monotone",
            "clip": true
          },
          "encoding": {
            "x": {
              "field": "date",
              "type": "temporal",
              "scale": {"domain": ["2025-12-20", "2026-05-10"]},
              "axis": {
                "values": [
                  "2026-01-01",
                  "2026-02-01",
                  "2026-03-01",
                  "2026-04-01",
                  "2026-05-01"
                ],
                "format": "%b"
              }
            },
            "y": {
              "field": "fpi",
              "type": "quantitative",
              "scale": {"domain": [-15000, 5000]},
              "axis": {
                "values": [-12000, -8000, -4000, 0, 4000],
                "labelExpr": "format(datum.value, ',')",
                "title": "US$ million",
                "titleColor": "#6B7280",
                "titleFontSize": 10,
                "titleFontWeight": "normal"
              }
            },
            "tooltip": [
              {
                "field": "date",
                "type": "temporal",
                "format": "%B %Y",
                "title": "Month"
              },
              {
                "field": "fpi",
                "type": "quantitative",
                "format": ",.0f",
                "title": "Net FPI (US$ mn)"
              }
            ]
          }
        }
      ]
    },
    {
      "width": 260,
      "height": 220,
      "title": "Panel C   ₹ per US$ (monthly average)",
      "data": {
        "url": "https://raw.githubusercontent.com/vkumarilse/vkumarilse.github.io/refs/heads/main/exchginrusd.csv",
        "format": {
          "type": "csv",
          "parse": {"observation_date": "date:'%d-%m-%Y'", "DEXINUS": "number"}
        }
      },
      "transform": [
        {"filter": "isValid(datum.DEXINUS)"},
        {"filter": "year(datum.observation_date) == 2026"}
      ],
      "layer": [
        {
          "data": {"values": [{"d": "2026-02-28"}]},
          "mark": {
            "type": "rule",
            "strokeDash": [4, 3],
            "strokeWidth": 1.5,
            "color": "#9CA3AF"
          },
          "encoding": {"x": {"field": "d", "type": "temporal"}}
        },
        {
          "mark": {
            "type": "line",
            "point": {"filled": true, "size": 50, "color": "#185FA5"},
            "strokeWidth": 2.5,
            "color": "#185FA5",
            "interpolate": "monotone",
            "clip": true
          },
          "encoding": {
            "x": {
              "field": "observation_date",
              "type": "temporal",
              "scale": {"domain": ["2025-12-20", "2026-05-10"]},
              "axis": {
                "values": [
                  "2026-01-01",
                  "2026-02-01",
                  "2026-03-01",
                  "2026-04-01",
                  "2026-05-01"
                ],
                "format": "%b"
              }
            },
            "y": {
              "field": "DEXINUS",
              "type": "quantitative",
              "scale": {"domain": [89, 97]},
              "axis": {
                "orient": "right",
                "values": [90, 92, 94, 96],
                "labelExpr": "'₹' + datum.value"
              }
            },
            "tooltip": [
              {
                "field": "observation_date",
                "type": "temporal",
                "format": "%B %Y",
                "title": "Month"
              },
              {
                "field": "DEXINUS",
                "type": "quantitative",
                "format": ".2f",
                "title": "₹ per US$"
              }
            ]
          }
        }
      ]
    }
  ]
}