{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.2.0.json",
  "width": 450,
  "height": 360,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "layer": [
    {
      "description": "Episode shading \u2014 2022 and 2026 stress periods",
      "data": {
        "values": [
          {
            "x1": "2022-02-01",
            "x2": "2022-12-31",
            "y1": 72,
            "y2": 100
          },
          {
            "x1": "2026-02-01",
            "x2": "2026-05-31",
            "y1": 72,
            "y2": 100
          }
        ]
      },
      "mark": {
        "type": "rect",
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "x1",
          "type": "temporal",
          "scale": {
            "domain": [
              "2021-10-01",
              "2026-08-01"
            ]
          }
        },
        "x2": {
          "field": "x2",
          "type": "temporal"
        },
        "y": {
          "field": "y1",
          "type": "quantitative",
          "scale": {
            "domain": [
              72,
              100
            ]
          }
        },
        "y2": {
          "field": "y2",
          "type": "quantitative"
        },
        "color": {
          "value": "#F4C245"
        },
        "opacity": {
          "value": 0.15
        },
        "stroke": {
          "value": null
        }
      }
    },
    {
      "description": "Vertical event lines \u2014 Ukraine invasion, JPMorgan GBI-EM inclusion, Hormuz closure",
      "data": {
        "values": [
          {
            "event_date": "2022-02-01",
            "event": "Ukraine invasion"
          },
          {
            "event_date": "2026-02-01",
            "event": "Hormuz closure"
          }
        ]
      },
      "mark": {
        "type": "rule",
        "strokeDash": [
          4,
          3
        ],
        "strokeWidth": 1.5,
        "color": "#676A86"
      },
      "encoding": {
        "x": {
          "field": "event_date",
          "type": "temporal"
        }
      }
    },
    {
      "description": "Main INR/USD line \u2014 loaded from exchginrusd.csv",
      "data": {
        "url": "https://raw.githubusercontent.com/vkumarilse/vkumarilse.github.io/refs/heads/main/exchginrusd.csv",
        "format": {
          "type": "csv",
          "parse": {
            "observation_date": "date:'%d-%m-%Y'",
            "DEXINUS": "number"
          }
        }
      },
      "transform": [
        {
          "filter": "isValid(datum.DEXINUS)"
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 2.5,
        "interpolate": "monotone",
        "clip": true,
        "color": "#179fdb"
      },
      "encoding": {
        "x": {
          "field": "observation_date",
          "type": "temporal",
          "scale": {
            "domain": [
              "2021-10-01",
              "2026-08-01"
            ]
          },
          "axis": {
            "values": [
              "2022-01-01",
              "2023-01-01",
              "2024-01-01",
              "2025-01-01",
              "2026-01-01"
            ],
            "format": "%Y",
            "labelAngle": 0,
            "title": null,
            "gridColor": "transparent",
            "tickSize": 4
          }
        },
        "y": {
          "field": "DEXINUS",
          "type": "quantitative",
          "scale": {
            "domain": [
              72,
              100
            ]
          },
          "axis": {
            "values": [
              75,
              80,
              85,
              90,
              95,
              100
            ],
            "labelExpr": "'\u20b9' + datum.value",
            "title": null,
            "tickColor": "transparent",
            "domainColor": "transparent",
            "gridWidth": 1
          }
        }
      }
    },
    {
      "description": "Tooltip hover overlay \u2014 same source as main line",
      "data": {
        "url": "https://raw.githubusercontent.com/vkumarilse/vkumarilse.github.io/refs/heads/main/exchginrusd.csv",
        "format": {
          "type": "csv",
          "parse": {
            "observation_date": "date:'%d-%m-%Y'",
            "DEXINUS": "number"
          }
        }
      },
      "transform": [
        {
          "filter": "isValid(datum.DEXINUS)"
        }
      ],
      "mark": {
        "type": "point",
        "opacity": 0,
        "size": 100
      },
      "encoding": {
        "x": {
          "field": "observation_date",
          "type": "temporal"
        },
        "y": {
          "field": "DEXINUS",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "observation_date",
            "type": "temporal",
            "format": "%B %Y",
            "title": "Month"
          },
          {
            "field": "DEXINUS",
            "type": "quantitative",
            "format": ".2f",
            "title": "\u20b9 per US$"
          }
        ]
      }
    },
    {
      "description": "Highlight dots \u2014 Dec 2022 monthly peak and May 2026 intraday record (not in CSV)",
      "data": {
        "values": [
          {
            "observation_date": "2022-12-01",
            "DEXINUS": 82.47,
            "note": "2022 peak"
          },
          {
            "observation_date": "2026-05-20",
            "DEXINUS": 96.89,
            "note": "May 2026 record (intraday, RBI 2026b)"
          }
        ]
      },
      "mark": {
        "type": "point",
        "size": 55,
        "filled": true,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "observation_date",
          "type": "temporal"
        },
        "y": {
          "field": "DEXINUS",
          "type": "quantitative"
        },
        "color": {
          "value": "#E6224B"
        }
      }
    },
    {
      "description": "Value labels for the two highlight points",
      "data": {
        "values": [
          {
            "observation_date": "2022-12-01",
            "DEXINUS": 82.47,
            "label": "\u20b982.47 (2022 peak)"
          },
          {
            "observation_date": "2026-05-01",
            "DEXINUS": 96.82,
            "label": "\u20b996.82 (record)"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontWeight": "bold",
        "align": "left",
        "dx": -53,
        "dy": -13,
        "clip": true
      },
      "encoding": {
        "x": {
          "field": "observation_date",
          "type": "temporal"
        },
        "y": {
          "field": "DEXINUS",
          "type": "quantitative"
        },
        "text": {
          "field": "label"
        }
      }
    }
  ],
  "title": {
    "text": [
      "Source: Federal Reserve H.10"
    ],
    "orient": "bottom",
    "fontStyle": "italic",
    "fontSize": 10,
    "color": "#676A8680",
    "fontWeight": "normal",
    "frame": "group",
    "dx": 0,
    "offset": 7
  },
  "config": {
    "font": "Circular Std",
    "text": {
      "color": "#676A86",
      "align": "left",
      "baseline": "middle",
      "dx": 7,
      "dy": 0,
      "fontSize": 11
    },
    "view": {
      "stroke": null,
      "continuousWidth": 400,
      "continuousHeight": 300,
      "discreteWidth": 400,
      "discreteHeight": 300
    },
    "range": {
      "category": [
        "#36B7B4",
        "#E6224B",
        "#F4C245",
        "#0063AF",
        "#00A767",
        "#179FDB",
        "#EB5C2E"
      ],
      "diverging": [
        "#E6224B",
        "#E54753",
        "#C9C9C9",
        "#179FDB",
        "#122B39"
      ],
      "heatmap": [
        "#C9C9C9",
        "#179FDB",
        "#0063AF",
        "#122B39"
      ],
      "ordinal": [
        "#00A767",
        "#36B7B4",
        "#179FDB",
        "#0063AF",
        "#243B5A"
      ]
    },
    "bar": {
      "color": "#179fdb"
    },
    "line": {
      "color": "#e6224b"
    },
    "rule": {
      "color": "#676A86"
    },
    "area": {
      "opacity": 0.3
    },
    "point": {
      "filled": true,
      "size": 80,
      "color": "#e6224b",
      "opacity": 0.95
    },
    "geoshape": {
      "stroke": "white",
      "strokeWidth": 0.3
    },
    "rect": {
      "fill": "#d6d4d4",
      "opacity": 0.3
    },
    "axis": {
      "labelColor": "#676A86",
      "labelFontSize": 11,
      "labelFont": "Circular Std",
      "labelOpacity": 0.7,
      "tickColor": "#676A86",
      "tickOpacity": 0.5,
      "domainColor": "#676A86",
      "domainOpacity": 0.5,
      "gridColor": "#676A86",
      "gridDash": [
        2,
        2
      ],
      "gridOpacity": 0.5,
      "title": null,
      "titleColor": "#676A86",
      "titleOpacity": 0.8,
      "tickSize": 4,
      "grid": false
    },
    "axisXDiscrete": {
      "grid": false,
      "labelAngle": 0,
      "tickCount": 10,
      "tickOpacity": 0.5,
      "title": null
    },
    "axisYDiscrete": {
      "ticks": false,
      "labelPadding": 5,
      "grid": false
    },
    "axisXTemporal": {
      "grid": false,
      "ticks": true
    },
    "axisXQuantitative": {
      "grid": false
    },
    "axisYQuantitative": {
      "gridColor": "#676A86",
      "gridDash": [
        1,
        5
      ],
      "gridOpacity": 0.5,
      "ticks": false,
      "labelPadding": 5,
      "tickCount": 8,
      "titleAngle": 0,
      "titleAlign": "left",
      "titleBaseline": "bottom",
      "titleX": 0,
      "titleY": -5,
      "grid": false
    },
    "title": {
      "color": "#676A86E6",
      "subtitleColor": "#676A86",
      "font": "Circular Std",
      "subtitleFont": "Circular Std",
      "anchor": "start",
      "fontSize": 14,
      "subtitleFontSize": 12,
      "subtitlePadding": 4,
      "offset": 0,
      "frame": "group"
    },
    "legend": {
      "titleColor": "#122b39",
      "title": null,
      "labelColor": "#122b39",
      "labelFontSize": 11
    }
  }
}