              0.6
            ]
          },
          "title": "Share of businesses in a cutting-edge sector that are located in a city centre",
          "type": "quantitative"
        },
        "y": {
          "axis": {
            "format": ".1%",
            "tickCount": 10
          },
          "field": "uk_share",
          "scale": {
            "domain": [
              0,
              0.045
            ]
          },
          "title": "Share of UK total",
          "type": "quantitative"
        }
      },
      "transform": [
        {
          "calculate": "toNumber(replace(datum['Share in City Centres (Registered)'], '%', '')) / 100",
          "as": "city_centre_share"
        },
        {
          "calculate": "toNumber(replace(datum['Northumberland, Durham and Tyne & Wear'], '%', '')) / 100",
          "as": "uk_share"
        },
        {
          "filter": "datum.Sector != null && trim(datum.Sector) !== '' && datum.Sector !== 'All Business Share' && isValid(datum.city_centre_share) && isValid(datum.uk_share)"
        }
      ]
    },
    {
      "mark": {
        "type": "rule",
        "color": "black",
        "strokeWidth": 1.8
      },
      "encoding": {
        "y": {
          "field": "all_business_share",
          "type": "quantitative"
        }
      },
      "transform": [
        {
          "filter": "datum['All business share'] != null && trim(datum['All business share']) !== ''"
        },
        {
          "calculate": "toNumber(replace(datum['All business share'], '%', '')) / 100",
          "as": "all_business_share"
        }
      ]
    },
    {
